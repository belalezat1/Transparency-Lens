# Copy to .env and fill in your values

PORT=3001

# MongoDB Atlas — create a free cluster at mongodb.com/atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/transparency_lens?retryWrites=true&w=majority

# Google Gemini API key — get at aistudio.google.com
# Set GEMMA_MODEL to the current Gemma 4 model ID (check ai.google.dev/gemma/docs)
GEMINI_API_KEY=your_gemini_api_key_here
GEMMA_MODEL=gemma-3-4b-it

# Snowflake — sign up at app.snowflake.com (student 120-day trial available)
# ACCOUNT format: orgname-accountname (e.g. abc12345.us-east-1)
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=TRANSPARENCY_LENS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
